generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DrawHistory {
  id           Int      @id @default(autoincrement())
  roundId      Int      @unique
  jackpot      Float
  participants Int
  winner1      String
  winner2      String?
  winner3      String?
  winner1Prize Float
  winner2Prize Float?
  winner3Prize Float?
  transactionHash String @default("legacy")
  timestamp    DateTime @default(now())
}

model DoubleRoundResult {
  id              Int      @id @default(autoincrement())
  roundId         Int      @unique
  number          Int
  color           Int      // 1=Red, 2=Black, 3=White
  totalPayout     Float
  transactionHash String   @default("legacy")
  timestamp       DateTime @default(now())
}

model DoubleBet {
  id              Int      @id @default(autoincrement())
  roundId         Int
  player          String
  color           Int
  amount          Float
  transactionHash String   @default("legacy")
  timestamp       DateTime @default(now())

  @@unique([roundId, player, color, amount, transactionHash])
}
